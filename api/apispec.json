                      }
                    ],
                    "pagination": {
                      "current_page": 1,
                      "per_page": 10,
                      "total_items": 1,
                      "total_pages": 1
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/admin/transactions": {
      "get": {
        "tags": ["Admin"],
        "summary": "Monitor all transactions (Admin only)",
        "description": "Retrieves paginated list of ALL transactions across the system. Supports filtering by transaction type and status. Only accessible by users with ADMIN role.",
        "operationId": "adminGetAllTransactions",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-based)",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by transaction type",
            "schema": {
              "type": "string",
              "enum": ["TOPUP", "TRANSFER"]
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by transaction status",
            "schema": {
              "type": "string",
              "enum": ["PENDING", "COMPLETED", "FAILED"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All transactions retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "Transactions retrieved successfully",
                  "data": {
                    "transactions": [
                      {
                        "transaction_id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
                        "reference_no": "TXN-20260528-KQ82VN5P",
                        "type": "TRANSFER",
                        "status": "COMPLETED",
                        "amount": "250000.00",
                        "source_wallet_id": "WLT-3KF91XA2B7",
                        "target_wallet_id": "WLT-9BZ42YR7E1",
                        "created_at": "2026-05-28T17:00:00Z"
                      },
                      {
                        "transaction_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
                        "reference_no": "TXN-20260528-AX91KDM3",
                        "type": "TOPUP",
                        "status": "COMPLETED",
                        "amount": "500000.00",
                        "source_wallet_id": null,
                        "target_wallet_id": "WLT-3KF91XA2B7",
                        "created_at": "2026-05-28T16:45:00Z"
                      }
                    ],
                    "pagination": {
                      "current_page": 1,
                      "per_page": 10,
                      "total_items": 2,
                      "total_pages": 1
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
